{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Reported Dengue Cases from Year 1999 to 2019",
  "width": "container",
  "height": 400,
  "data": {
    "url": "./vegalite/ten_year_trend/DatasetDenggiMalaysia_v2.csv" 
  },
  "transform": [
    {
      "calculate": "datum.TAHUN", 
      "as": "Negeri"
    },
    {
      "filter": "datum.TAHUN != 'NEGERI'"
    },
    {
      "fold": ["1999", "2000", "2001", "2002", "2003", "2004", "2005", "2006", "2007", "2008", "2009", "2010", "2011", "2012", "2013", "2014", "2015", "2016", "2017", "2018", "2019"],
      "as": ["Year", "Cases"]
    },
    {
      "calculate": "toNumber(datum.Cases)",
      "as": "Cases_Num"
    }
  ],
  "mark": {"type":"line", "point":true},
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year",
      "sort": {"field": "Year"},
      "axis": {"labelAngle": 360}
    },
    "y": {
      "aggregate": "sum",
      "field": "Cases_Num",
      "type": "quantitative",
      "title": "Number of Cases"
    },
    "tooltip": [
      {"field": "Year", "title": "Year"},
      {"aggregate": "sum", "field": "Cases_Num", "title": "Number of Cases", "format": ","}
    ]

  }
}