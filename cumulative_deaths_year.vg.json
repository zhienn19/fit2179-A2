{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Number of Deaths by Dengue from 2012 to 2021",
  "width": "container",
  "height": 400,
  "data": {
    "url": "./vegalite/mortality/dengue_mortality_trends_malaysia.csv" 
  },

  "transform": [
    {
      "sort": [{"field": "Year"}],
      "window": [{
        "op": "sum",
        "field": "Number_of_Deaths",
        "as": "Cumulative_Deaths"
      }]
    }
  ],
  "mark": {
    "type": "area",
    "line": true,
    "opacity": 0.4
  },

  "encoding": {
    "x": {
      "field": "Year", 
      "type": "ordinal", 
      "title": "Year",
      "axis": {"labelAngle": 360}
    },
   
    "y": {
      "field": "Number_of_Deaths",
      "type": "quantitative",
      "title": "Number of Deaths"
    },
    "tooltip": [
        { "field": "Year", "title": "Year"},
        {"field": "Number_of_Deaths", "title": "Number of Deaths"},
        {"field": "Cumulative_Deaths", "type": "quantitative", "title": "Cumulative Deaths to Date"}
    ]
  }
}