{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Reported Dengue Cases over 20 years (1999 - 2019)",
    "subtitle": "Interactive map tracing historical cases per 100,000 people (1999 to 2019).",
    "fontSize": 18,
    "anchor": "start"
  },
  "width": "container",
  "height": 450,
  "autosize": {
    "type": "fit",
    "contains": "content"
  },

  "padding": {
  "left": 20,
  "right": 20,
  "top": 20,
  "bottom": 20
},
  
  "params": [
    {
      "name": "Select_Year",
      "value": 2019,
      "bind": {
        "input": "range",
        "min": 1999,
        "max": 2019,
        "step": 1,
        "name": "Select Year: "
      }
    }
  ],

  "projection": {
    "type": "mercator",
    "center": [109.5, 4.2],
    "scale": 2500
  },


  "layer": [
    {
      "data": {
        "url": "clipped_map.json",
        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_0_countries"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f0f0f0",
        "stroke": "#d9d9d9",
        "strokeWidth": 0.5
      },
      "encoding": {
        "tooltip": [
          {"field": "properties.NAME", "type": "nominal", "title": "Country"}
        ]
      }
    },
    {
      "data": {
        "url": "DatasetDenggiMalaysia_Normalized.csv"
      },
      "transform": [
        {
          "filter": "datum.Year == Select_Year"
        },
        {
          "calculate": "{'WPKL/PUTRAJAYA': ['Kuala Lumpur', 'Putrajaya'], 'N.SEMBILAN': ['Negeri Sembilan'], 'PULAU PINANG': ['Penang'], 'MELAKA': ['Malacca'], 'JOHOR': ['Johor'], 'KEDAH': ['Kedah'], 'KELANTAN': ['Kelantan'], 'PAHANG': ['Pahang'], 'PERAK': ['Perak'], 'PERLIS': ['Perlis'], 'SABAH': ['Sabah'], 'SARAWAK': ['Sarawak'], 'SELANGOR': ['Selangor'], 'TERENGGANU': ['Terengganu'], 'LABUAN': ['Labuan']}[datum.State] || [datum.State]",
          "as": "shapeName"
        },
        {
          "flatten": ["shapeName"]
        },
        {
          "lookup": "shapeName",
          "from": {
            "data": {
              "url": "clipped_map.json",
              "format": {
                "type": "topojson",
                "feature": "geoBoundaries-MYS-ADM1"
              }
            },
            "key": "properties.shapeName"
          },
          "as": "geo"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.6
      },
      "encoding": {
        "shape": {
          "field": "geo",
          "type": "geojson"
        },
        "color": {
  "field": "Cases_Per_100k",
  "type": "quantitative",
  "scale": {
    "type": "threshold",
    "domain": [50, 150, 300, 600],
    "scheme": "purples"
  },
  "legend": {
    "type": "symbol",
    "symbolType": "square",
    "symbolSize": 150,
    "title": "Dengue cases per 100k people",
    "titleOrient": "top",
    "orient": "right",
    "labelFontSize": 12,
    "titleFontSize": 14,
    "direction": "vertical",
    "padding": 10,
    "titleLimit": 300,
    "labelOffset": 12,
    "values": [49, 149, 299, 599, 601],
    "labelExpr": "datum.value === 49 ? '0 - 50' : datum.value === 149 ? '50 - 150' : datum.value === 299 ? '150 - 300' : datum.value === 599 ? '300 - 600' : '≥ 600'"
  }
},
        "tooltip": [
          {
            "field": "shapeName",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "Cases",
            "type": "quantitative",
            "title": "Raw Dengue Cases",
            "format": ","
          },
          {
            "field": "Cases_Per_100k",
            "type": "quantitative",
            "title": "Cases per 100,000 people",
            "format": ".2f"
          },
          {
            "field": "Year",
            "type": "quantitative",
            "title": "Year"
          }
        ]
      }
    }
  ]
}